{
  "name": "magic-table-tracker",
  "private": true,
  "type": "module",
  "scripts": {
    "hyperframes:lint": "cd hyperframes/mtg-table-tracker && npx hyperframes lint",
    "hyperframes:validate": "cd hyperframes/mtg-table-tracker && npx hyperframes validate",
    "hyperframes:inspect": "cd hyperframes/mtg-table-tracker && npx hyperframes inspect",
    "hyperframes:preview": "cd hyperframes/mtg-table-tracker && npx hyperframes preview",
